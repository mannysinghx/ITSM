{
  "name": "flowdesk-itsm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.migrate -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.migrate -- prisma migrate deploy",
    "db:rls": "dotenv -e .env.migrate -- tsx prisma/apply-rls.ts",
    "seed": "dotenv -e .env.migrate -- tsx prisma/seed.ts",
    "release": "bash scripts/release.sh",
    "seed:prod": "tsx prisma/seed.ts",
    "demo:seed": "tsx prisma/seed-demo.ts",
    "demo:purge": "tsx prisma/purge-demo.ts",
    "demo:fill-accounts": "tsx prisma/fill-accounts.ts",
    "test": "dotenv -e .env -- vitest run",
    "test:watch": "dotenv -e .env -- vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "next": "^15.1.4",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^8.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "esbuild", "bcrypt"]
  }
}

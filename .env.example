# --- Runtime (.env): APP role, RLS-enforced. Used by Next.js and tests. ---
DATABASE_URL="postgresql://flowdesk_app:CHANGE_ME@localhost:5432/flowdesk?schema=public"
SESSION_SECRET="generate-a-32+-byte-random-secret"
NODE_ENV="development"

# --- Migrations/seed (.env.migrate): MIGRATOR role (table owner). ---
# DATABASE_URL="postgresql://flowdesk_migrator:CHANGE_ME@localhost:5432/flowdesk?schema=public"

# Two distinct DB roles are REQUIRED (ADR-1):
#   flowdesk_migrator — owns tables, runs migrations/seed, bypasses RLS as owner
#   flowdesk_app      — runtime role, NOT owner / NOT superuser / NOT BYPASSRLS
# If the app connects as the owner, RLS silently does nothing.

# --- Optional (post-MVP hooks; all have safe defaults) ---
# AI_API_KEY=""              # unset => deterministic mock provider (Phase 6)
# STORAGE_DIR="./.storage"   # local attachment storage (Phase 2)
# SMTP_URL=""                # unset => mock email transport (Phases 4/8)
# REDIS_URL=""               # unset => in-memory rate limiter (Phase 8); use Redis in prod
# SENTRY_DSN=""              # observability (Phase 8, deferred)

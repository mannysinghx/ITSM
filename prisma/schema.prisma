// FlowDesk ITSM — Foundation schema (Phase 1)
// RLS designations (see ADR-1):
//   Global (no tenant_id, NOT rls): users, sessions, roles, permissions, role_permissions
//   Tenant-owned (tenant_id, RLS enabled+forced): tenants, tenant_memberships, teams,
//       team_memberships, user_role_assignments, audit_logs, tenant_counters
// RLS policies + role grants are applied by prisma/apply-rls.ts (raw SQL), not by Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  invited
  suspended
}

enum TenantType {
  individual
  company
}

enum MembershipStatus {
  active
  invited
  suspended
}

enum RoleScope {
  system
  tenant
  team
}

/// Global identity. A user may belong to many tenants. NOT tenant-scoped, NOT RLS.
model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  emailVerified Boolean  @default(false) @map("email_verified")
  avatarUrl     String?  @map("avatar_url")
  status        UserStatus @default(active)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ownedTenants     Tenant[]           @relation("TenantOwner")
  memberships      TenantMembership[]
  teamMemberships  TeamMembership[]
  roleAssignments  UserRoleAssignment[]
  sessions         Session[]

  @@map("users")
}

/// Server-side session. Global (keyed by user). Stores the active tenant for the session.
model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  activeTenantId String?  @map("active_tenant_id") @db.Uuid
  tokenHash      String   @unique @map("token_hash")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// A tenant is the isolation boundary. type=individual => one default team.
model Tenant {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  slug        String     @unique
  type        TenantType
  ownerUserId String     @map("owner_user_id") @db.Uuid
  plan        String     @default("free")
  settings    Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner           User                 @relation("TenantOwner", fields: [ownerUserId], references: [id])
  memberships     TenantMembership[]
  teams           Team[]
  roleAssignments UserRoleAssignment[]
  auditLogs       AuditLog[]
  counter         TenantCounter?

  @@map("tenants")
}

model TenantMembership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_memberships")
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  slug        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]

  @@unique([tenantId, slug])
  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String?  @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role? @relation(fields: [roleId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

/// Roles: system roles have tenantId=null. Global config table (NOT RLS); custom
/// tenant roles (Phase 3) are filtered by tenantId in the app layer.
model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  name        String
  key         String
  description String?
  scope       RoleScope @default(tenant)
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  permissions     RolePermission[]
  assignments     UserRoleAssignment[]
  teamMemberships TeamMembership[]

  @@unique([tenantId, key])
  @@map("roles")
}

/// Permission vocabulary. Global config (NOT RLS).
model Permission {
  id          String @id @default(uuid()) @db.Uuid
  key         String @unique
  description String
  category    String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Assigns a role to a user, optionally scoped to a team. expiresAt => temporary grant (ADR-3).
model UserRoleAssignment {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  teamId    String?   @map("team_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId, userId])
  @@map("user_role_assignments")
}

/// Append-only (ADR-8): app role has INSERT+SELECT only; no UPDATE/DELETE.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  teamId     String?  @map("team_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

/// Per-tenant atomic counter for ticket numbering (ADR-7). Used from Phase 2.
model TenantCounter {
  tenantId  String @id @map("tenant_id") @db.Uuid
  ticketSeq Int    @default(0) @map("ticket_seq")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_counters")
}

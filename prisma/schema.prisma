// FlowDesk ITSM — Foundation schema (Phase 1)
// RLS designations (see ADR-1):
//   Global (no tenant_id, NOT rls): users, sessions, roles, permissions, role_permissions
//   Tenant-owned (tenant_id, RLS enabled+forced): tenants, tenant_memberships, teams,
//       team_memberships, user_role_assignments, audit_logs, tenant_counters
// RLS policies + role grants are applied by prisma/apply-rls.ts (raw SQL), not by Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  invited
  suspended
}

enum TenantType {
  individual
  company
}

enum MembershipStatus {
  active
  invited
  suspended
}

enum RoleScope {
  system
  tenant
  team
}

// --- Phase 2 (Tickets) ---

enum Severity {
  low
  medium
  high
  critical
}

enum Priority {
  p1
  p2
  p3
  p4
}

enum TicketSource {
  portal
  email
  api
  admin
  ai
}

enum StatusCategory {
  open
  pending
  resolved
  closed
  cancelled
}

enum LinkRelation {
  relates
  blocks
  duplicate
  parent
  child
}

// --- Phase 3 (Admin) ---

enum FieldType {
  text
  number
  select
  date
  bool
}

// --- Phase 4 (Tasks & SLAs) ---

enum TaskStatus {
  todo
  in_progress
  blocked
  done
  cancelled
}

enum SlaKind {
  first_response
  resolution
}

// --- Phase 5 (Service Catalog) ---

enum CatalogVisibility {
  public
  internal
  team
}

enum ApprovalStatus {
  pending
  approved
  rejected
  skipped
}

// --- Phase 6 (AI) ---

enum AiUseCase {
  classify
  priority
  team
  summarize
  draft
  knowledge
}

enum AiStatus {
  ok
  error
  budget_blocked
  disabled
}

enum KnowledgeStatus {
  draft
  published
  archived
}

enum KnowledgeSource {
  human
  ai
  ticket
}

/// Global identity. A user may belong to many tenants. NOT tenant-scoped, NOT RLS.
model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  emailVerified Boolean  @default(false) @map("email_verified")
  avatarUrl     String?  @map("avatar_url")
  status        UserStatus @default(active)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ownedTenants     Tenant[]           @relation("TenantOwner")
  memberships      TenantMembership[]
  teamMemberships  TeamMembership[]
  roleAssignments  UserRoleAssignment[]
  sessions         Session[]
  requestedTickets Ticket[]           @relation("TicketRequester")
  assignedTickets  Ticket[]           @relation("TicketAssignee")
  assignedTasks    Task[]             @relation("TaskAssignee")
  notifications    Notification[]
  notificationPrefs NotificationPreference[]

  @@map("users")
}

/// Server-side session. Global (keyed by user). Stores the active tenant for the session.
model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  activeTenantId String?  @map("active_tenant_id") @db.Uuid
  tokenHash      String   @unique @map("token_hash")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// A tenant is the isolation boundary. type=individual => one default team.
model Tenant {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  slug        String     @unique
  type        TenantType
  ownerUserId String     @map("owner_user_id") @db.Uuid
  plan        String     @default("free")
  settings    Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner           User                 @relation("TenantOwner", fields: [ownerUserId], references: [id])
  memberships     TenantMembership[]
  teams           Team[]
  roleAssignments UserRoleAssignment[]
  auditLogs       AuditLog[]
  counter         TenantCounter?
  tickets         Ticket[]
  ticketStatuses  TicketStatus[]
  ticketTypes     TicketType[]
  priorityMatrix  PriorityMatrixEntry[]
  categories      Category[]
  ticketFieldDefs TicketFieldDef[]
  slaPolicies     SLAPolicy[]
  businessHours   BusinessHours[]
  holidayCalendars HolidayCalendar[]
  catalogItems    ServiceCatalogItem[]
  formDefinitions FormDefinition[]
  approvals       Approval[]
  aiRequests      AIRequest[]
  aiTokenUsage    AITokenUsage[]
  knowledgeArticles KnowledgeArticle[]

  @@map("tenants")
}

model TenantMembership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_memberships")
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  slug        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]
  tickets     Ticket[]
  tasks       Task[]

  @@unique([tenantId, slug])
  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String?  @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role? @relation(fields: [roleId], references: [id])

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

/// Roles: system roles have tenantId=null. Global config table (NOT RLS); custom
/// tenant roles (Phase 3) are filtered by tenantId in the app layer.
model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  name        String
  key         String
  description String?
  scope       RoleScope @default(tenant)
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  permissions     RolePermission[]
  assignments     UserRoleAssignment[]
  teamMemberships TeamMembership[]

  @@unique([tenantId, key])
  @@map("roles")
}

/// Permission vocabulary. Global config (NOT RLS).
model Permission {
  id          String @id @default(uuid()) @db.Uuid
  key         String @unique
  description String
  category    String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Assigns a role to a user, optionally scoped to a team. expiresAt => temporary grant (ADR-3).
model UserRoleAssignment {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  teamId    String?   @map("team_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId, userId])
  @@map("user_role_assignments")
}

/// Append-only (ADR-8): app role has INSERT+SELECT only; no UPDATE/DELETE.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  teamId     String?  @map("team_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

/// Per-tenant atomic counter for ticket numbering (ADR-7). Used from Phase 2.
model TenantCounter {
  tenantId  String @id @map("tenant_id") @db.Uuid
  ticketSeq Int    @default(0) @map("ticket_seq")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_counters")
}

// --- Phase 2: ticket configuration (FK tables, seeded read-only in MVP — ADR-5) ---

model TicketStatus {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  key       String
  name      String
  category  StatusCategory
  order     Int            @default(0)
  isSystem  Boolean        @default(true) @map("is_system")
  isDefault Boolean        @default(false) @map("is_default")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@unique([tenantId, key])
  @@map("ticket_statuses")
}

model TicketType {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  key      String
  name     String
  isSystem Boolean @default(true) @map("is_system")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@unique([tenantId, key])
  @@map("ticket_types")
}

model PriorityMatrixEntry {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  impact   Severity
  urgency  Severity
  priority Priority

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, impact, urgency])
  @@map("priority_matrix")
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  name     String
  parentId String? @map("parent_id") @db.Uuid
  teamId   String? @map("team_id") @db.Uuid
  isSystem Boolean @default(true) @map("is_system")

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  tickets  Ticket[]

  @@unique([tenantId, name, parentId])
  @@map("categories")
}

// --- Phase 2: tickets + children ---

model Ticket {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  ticketNumber       String       @map("ticket_number")
  teamId             String       @map("team_id") @db.Uuid
  requesterId        String       @map("requester_id") @db.Uuid
  assigneeId         String?      @map("assignee_id") @db.Uuid
  title              String
  description        String
  typeId             String       @map("type_id") @db.Uuid
  categoryId         String?      @map("category_id") @db.Uuid
  statusId           String       @map("status_id") @db.Uuid
  impact             Severity     @default(medium)
  urgency            Severity     @default(medium)
  priority           Priority     @default(p3)
  source             TicketSource @default(portal)
  channel            String?
  customFields       Json         @default("{}") @map("custom_fields")
  tags               String[]     @default([])
  dueAt              DateTime?    @map("due_at")
  firstResponseDueAt DateTime?    @map("first_response_due_at")
  resolutionDueAt    DateTime?    @map("resolution_due_at")
  resolvedAt         DateTime?    @map("resolved_at")
  closedAt           DateTime?    @map("closed_at")
  createdById        String       @map("created_by") @db.Uuid
  updatedById        String?      @map("updated_by") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requester User         @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee  User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
  type      TicketType   @relation(fields: [typeId], references: [id])
  status    TicketStatus @relation(fields: [statusId], references: [id])
  category  Category?    @relation(fields: [categoryId], references: [id])

  comments    TicketComment[]
  history     TicketHistory[]
  attachments TicketAttachment[]
  watchers    TicketWatcher[]
  links       TicketLink[]       @relation("TicketLinkSource")
  tasks       Task[]             @relation("TicketTasks")
  slaTimers   SLATimer[]
  approvals   Approval[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, teamId])
  @@index([tenantId, statusId])
  @@index([tenantId, requesterId])
  @@index([tenantId, assigneeId])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  body       String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId])
  @@map("ticket_comments")
}

model TicketHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  field     String?
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId, createdAt])
  @@map("ticket_history")
}

model TicketAttachment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  commentId   String?  @map("comment_id") @db.Uuid
  uploaderId  String   @map("uploader_id") @db.Uuid
  filename    String
  contentType String   @map("content_type")
  byteSize    Int      @map("byte_size")
  storageKey  String   @map("storage_key")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

model TicketWatcher {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@map("ticket_watchers")
}

model TicketLink {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  ticketId       String       @map("ticket_id") @db.Uuid
  linkedTicketId String       @map("linked_ticket_id") @db.Uuid
  relation       LinkRelation @default(relates)
  createdAt      DateTime     @default(now()) @map("created_at")

  ticket Ticket @relation("TicketLinkSource", fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, linkedTicketId, relation])
  @@map("ticket_links")
}

/// Custom-field definitions driving tickets.customFields JSONB (ADR-5, not filterable).
model TicketFieldDef {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  key        String
  label      String
  fieldType  FieldType @default(text) @map("field_type")
  options    Json      @default("[]")
  required   Boolean   @default(false)
  visibility Json      @default("{}")
  validation Json      @default("{}")
  order      Int       @default(0)
  isSystem   Boolean   @default(false) @map("is_system")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("ticket_field_defs")
}

// --- Phase 4: tasks ---

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  teamId      String     @map("team_id") @db.Uuid
  ticketId    String?    @map("ticket_id") @db.Uuid
  title       String
  description String?
  status      TaskStatus @default(todo)
  priority    Priority   @default(p3)
  assigneeId  String?    @map("assignee_id") @db.Uuid
  dueAt       DateTime?  @map("due_at")
  createdById String     @map("created_by") @db.Uuid
  updatedById String?    @map("updated_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  ticket   Ticket? @relation("TicketTasks", fields: [ticketId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  comments TaskComment[]
  history  TaskHistory[]

  @@index([tenantId, teamId])
  @@index([tenantId, ticketId])
  @@index([tenantId, assigneeId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId])
  @@map("task_comments")
}

model TaskHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  field     String?
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId, createdAt])
  @@map("task_history")
}

// --- Phase 4: SLA ---

model SLAPolicy {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  teamId               String?  @map("team_id") @db.Uuid
  name                 String
  description          String?
  ticketType           String?  @map("ticket_type")
  priority             Priority?
  firstResponseMinutes Int      @map("first_response_minutes")
  resolutionMinutes    Int      @map("resolution_minutes")
  businessHoursId      String?  @map("business_hours_id") @db.Uuid
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timers SLATimer[]

  @@index([tenantId, enabled])
  @@map("sla_policies")
}

model SLATimer {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  slaPolicyId String?   @map("sla_policy_id") @db.Uuid
  kind        SlaKind
  dueAt       DateTime  @map("due_at")
  warnAt      DateTime  @map("warn_at")
  startedAt   DateTime  @default(now()) @map("started_at")
  pausedAt    DateTime? @map("paused_at")
  warnedAt    DateTime? @map("warned_at")
  breachedAt  DateTime? @map("breached_at")
  satisfiedAt DateTime? @map("satisfied_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  ticket    Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  slaPolicy SLAPolicy? @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)

  @@unique([ticketId, kind])
  @@index([tenantId, satisfiedAt])
  @@map("sla_timers")
}

model BusinessHours {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  timezone       String   @default("UTC")
  weeklySchedule Json     @default("{}") @map("weekly_schedule")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("business_hours")
}

model HolidayCalendar {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  dates     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("holiday_calendars")
}

// --- Phase 4: notifications ---

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  title      String
  body       String
  type       String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventType String   @map("event_type")
  inApp     Boolean  @default(true) @map("in_app")
  email     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

// --- Phase 5: service catalog ---

model FormDefinition {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  schema    Json     @default("{\"fields\":[]}")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       ServiceCatalogItem[]
  submissions FormSubmission[]

  @@map("form_definitions")
}

model ServiceCatalogItem {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  teamId            String?           @map("team_id") @db.Uuid
  name              String
  description       String?
  category          String?
  formDefinitionId  String?           @map("form_definition_id") @db.Uuid
  defaultPriority   Priority          @default(p3) @map("default_priority")
  defaultSlaPolicyId String?          @map("default_sla_policy_id") @db.Uuid
  approvalRequired  Boolean           @default(false) @map("approval_required")
  approvalChain     Json              @default("[]") @map("approval_chain")
  routingRule       Json              @default("{}") @map("routing_rule")
  visibility        CatalogVisibility @default(internal)
  status            String            @default("active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formDefinition FormDefinition? @relation(fields: [formDefinitionId], references: [id])
  submissions    FormSubmission[]

  @@index([tenantId, visibility, status])
  @@map("service_catalog_items")
}

model FormSubmission {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  catalogItemId    String   @map("catalog_item_id") @db.Uuid
  formDefinitionId String?  @map("form_definition_id") @db.Uuid
  submittedById    String   @map("submitted_by") @db.Uuid
  values           Json     @default("{}")
  ticketId         String?  @map("ticket_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  catalogItem    ServiceCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  formDefinition FormDefinition?    @relation(fields: [formDefinitionId], references: [id])

  @@index([tenantId, catalogItemId])
  @@map("form_submissions")
}

model Approval {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  ticketId       String?        @map("ticket_id") @db.Uuid
  submissionId   String?        @map("submission_id") @db.Uuid
  sequence       Int
  approverUserId String?        @map("approver_user_id") @db.Uuid
  approverRole   String?        @map("approver_role")
  status         ApprovalStatus @default(pending)
  decidedById    String?        @map("decided_by") @db.Uuid
  decidedAt      DateTime?      @map("decided_at")
  comment        String?
  createdAt      DateTime       @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([ticketId, sequence])
  @@map("approvals")
}

// --- Phase 6: AI ---

model AIRequest {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  teamId           String?   @map("team_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  useCase          AiUseCase @map("use_case")
  provider         String
  model            String?
  isMock           Boolean   @default(true) @map("is_mock")
  redacted         Boolean   @default(false)
  promptTokens     Int       @default(0) @map("prompt_tokens")
  completionTokens Int       @default(0) @map("completion_tokens")
  costUsd          Float     @default(0) @map("cost_usd")
  latencyMs        Int       @default(0) @map("latency_ms")
  status           AiStatus  @default(ok)
  entityType       String?   @map("entity_type")
  entityId         String?   @map("entity_id")
  errorCode        String?   @map("error_code")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outputs AIOutput[]

  @@index([tenantId, createdAt])
  @@map("ai_requests")
}

model AIOutput {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  aiRequestId       String   @map("ai_request_id") @db.Uuid
  outputType        String   @map("output_type")
  content           Json     @default("{}")
  aiSuggested       Boolean  @default(true) @map("ai_suggested")
  accepted          Boolean?
  acceptedByUserId  String?  @map("accepted_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")

  aiRequest AIRequest @relation(fields: [aiRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ai_outputs")
}

model AITokenUsage {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  teamId           String?  @map("team_id") @db.Uuid
  userId           String?  @map("user_id") @db.Uuid
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  costUsd          Float    @default(0) @map("cost_usd")
  requestCount     Int      @default(0) @map("request_count")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, periodEnd])
  @@map("ai_token_usage")
}

model KnowledgeArticle {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  teamId           String?         @map("team_id") @db.Uuid
  title            String
  slug             String
  status           KnowledgeStatus @default(draft)
  source           KnowledgeSource @default(human)
  sourceTicketId   String?         @map("source_ticket_id") @db.Uuid
  currentVersionId String?         @map("current_version_id") @db.Uuid
  createdByUserId  String          @map("created_by_user_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  tenant   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions KnowledgeArticleVersion[]
  feedback KnowledgeFeedback[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("knowledge_articles")
}

model KnowledgeArticleVersion {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  articleId       String   @map("article_id") @db.Uuid
  version         Int
  body            String
  summary         String?
  aiGenerated     Boolean  @default(false) @map("ai_generated")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, version])
  @@map("knowledge_article_versions")
}

model KnowledgeFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  helpful   Boolean
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("knowledge_feedback")
}

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'worker service: no Next.js build needed'"
  },
  "deploy": {
    "startCommand": "pnpm tsx scripts/run-workers.ts",
    "cronSchedule": "*/5 * * * *",
    "restartPolicyType": "NEVER"
  }
}
